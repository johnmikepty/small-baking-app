<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Development profile: human-readable console output ── -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.smallbankapp.banking" level="DEBUG"/>
    </springProfile>

    <!-- ── Docker / Production profile: structured JSON logs ── -->
    <springProfile name="docker,prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.classic.encoder.JsonEncoder">
                <!-- Each log line is a single JSON object -->
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
        <logger name="com.smallbankapp.banking" level="INFO"/>
        <logger name="org.apache.kafka"          level="WARN"/>
        <logger name="org.flywaydb"              level="INFO"/>
    </springProfile>

    <!-- ── Test profile: minimal output ── -->
    <springProfile name="test">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss} %-5level %logger{20} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.smallbankapp.banking" level="INFO"/>
    </springProfile>

</configuration>
